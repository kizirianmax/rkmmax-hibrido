# =============================================================================
# rkmmax-hibrido — ENV VARS REFERENCE
# Última atualização: 2026-03-10
# Domínio de produção: https://kizirianmax.site
#
# COMO USAR:
#   1. Copie este arquivo para .env.local (nunca faça commit de .env.local)
#   2. Preencha os valores reais
#   3. Configure as mesmas variáveis no painel da Vercel:
#      https://vercel.com/rkmmax/rkmmax-hibrido/settings/environment-variables
# =============================================================================

# =============================================================================
# 🔴 CRÍTICAS — O app NÃO funciona sem estas
# =============================================================================

# --- AI Providers ---
# Groq: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Supabase (Backend DB + Auth) ---
# Painel: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (Frontend — prefixo REACT_APP_ para ser exposto ao browser)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# --- Stripe (Pagamentos) ---
# Painel: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY_RKMMAX=
STRIPE_WEBHOOK_SECRET=

# Stripe Payment Links (Frontend — copiar do rkmmax-app)
# Brasil (BRL)
REACT_APP_STRIPE_PAYMENT_LINK_BASIC_BR=
REACT_APP_STRIPE_PAYMENT_LINK_INTERMEDIATE_BR=
REACT_APP_STRIPE_PAYMENT_LINK_PREMIUM_BR=

# Estados Unidos (USD)
REACT_APP_STRIPE_PAYMENT_LINK_BASIC_US=
REACT_APP_STRIPE_PAYMENT_LINK_INTERMEDIATE_US=
REACT_APP_STRIPE_PAYMENT_LINK_PREMIUM_US=

# Cupom Educacional
REACT_APP_STRIPE_COUPON_EDU50=EDU50

# Default region (BR or US)
REACT_APP_REGION_DEFAULT=BR

# --- GitHub (Feedback / Issues) ---
# Token com permissão: repo (issues:write)
# Criar em: https://github.com/settings/tokens
GITHUB_TOKEN=
# Valor fixo para este projeto:
GITHUB_REPO=kizirianmax/rkmmax-hibrido

# --- GitHub OAuth (Login social) ---
# App OAuth: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Valor para produção:
GITHUB_OAUTH_REDIRECT_URI=https://kizirianmax.site/api/auth/github/callback

# --- GitHub Integração (Construtor) ---
# Feature flag: habilita ou desabilita a integração GitHub no backend.
# IMPORTANTE: false por padrão. Não habilite sem configurar as credenciais.
GITHUB_INTEGRATION_ENABLED=false
# Timeout para chamadas à API GitHub (ms). Padrão: 8000
GITHUB_REQUEST_TIMEOUT_MS=8000
# URL base da API GitHub (alterar apenas para GitHub Enterprise)
# GITHUB_API_BASE_URL=https://api.github.com

# --- Email (Resend) ---
# Painel: https://resend.com/api-keys
RESEND_API_KEY=
FROM_EMAIL=noreply@kizirianmax.site

# =============================================================================
# 🟡 OPCIONAIS — Observabilidade e features extras
# =============================================================================

# Sentry (Error tracking): https://sentry.io
REACT_APP_SENTRY_DSN=

# PostHog (Analytics): https://posthog.com
REACT_APP_POSTHOG_KEY=
REACT_APP_POSTHOG_HOST=https://app.posthog.com

# Anthropic (Claude — fallback de IA)
ANTHROPIC_API_KEY=

# OpenAI (fallback de IA)
OPENAI_API_KEY=

# Slack (alertas internos)
SLACK_WEBHOOK_URL=

# =============================================================================
# ⚙️ CONFIGURAÇÃO DO ORQUESTRADOR HÍBRIDO
# =============================================================================

# Pesos dos providers (JSON). Padrão: Groq puro.
# Exemplo multi-provider: {"groq":70,"gemini":30}
HYBRID_PROVIDER_WEIGHTS={"groq":100}

# URL canônica do site (usada em emails e redirects)
SITE_URL=https://kizirianmax.site

# =============================================================================
# 📦 VERSÃO DA APLICAÇÃO
# =============================================================================
REACT_APP_VERSION=2.0.0

# =============================================================================
# 🤖 VARIÁVEIS AUTOMÁTICAS DA VERCEL (não configurar manualmente)
# =============================================================================
# VERCEL_ENV          — "production" | "preview" | "development"
# VERCEL_URL          — URL do deploy atual (ex: rkmmax-hibrido-abc123.vercel.app)
# VERCEL_GIT_COMMIT_SHA — Hash do commit atual
# NODE_ENV            — "production" em produção
# =============================================================================
